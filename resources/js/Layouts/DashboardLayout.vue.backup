                                        fill="currentColor" />
                                </svg>
                            </button>

                            <!-- Notification Dropdown -->
                            <button type="button" class="-m-2.5 p-2.5 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white transition-colors">
                                <BellIcon class="h-6 w-6" />
                            </button>

                            <!-- Profile dropdown -->
                            <div class="relative">
                                <button @click="profileDropdownOpen = !profileDropdownOpen"
                                        class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 dark:focus:ring-gray-400">
                                    <div class="w-8 h-8 bg-yellow-500 rounded-full flex items-center justify-center shadow-lg">
                                        <span class="text-sm font-medium text-gray-900">
                                            {{ getUserInitials }}
                                        </span>
                                    </div>
                                </button>

                                <div v-show="profileDropdownOpen"
                                     @click.away="profileDropdownOpen = false"
                                     class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 py-1 shadow-xl">
                                    <Link :href="route('profile.show')"
                                          class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        Your Profile
                                    </Link>
                                    <Link :href="route('logout')" method="post" as="button"
                                          class="block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        Sign out
                                    </Link>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Page content -->
                <main class="py-6">
                    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                        <slot />
                    </div>
                </main>
            </div>
        </div>
</ThemeProvider>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { Link, usePage } from '@inertiajs/vue3'
import { getNavigationForRole } from '@/Utils/navigation.js'
import {
    Bars3Icon,
    BellIcon,
    ChevronDownIcon,
    HomeIcon,
    UserGroupIcon,
    CalendarDaysIcon,
    CurrencyDollarIcon,
    ClockIcon,
    TvIcon,
    ChartBarIcon,
    ChartPieIcon,
    CogIcon,
    DocumentTextIcon,
    WrenchScrewdriverIcon,
    BuildingOfficeIcon,
    UserIcon,
    BanknotesIcon,
    ClipboardDocumentListIcon,
    ShieldCheckIcon,
    UsersIcon,
    KeyIcon,
    ExclamationTriangleIcon,
    ArchiveBoxIcon,
    CreditCardIcon,
    ReceiptPercentIcon,
    DocumentIcon,
    CalculatorIcon,
    Cog6ToothIcon,
    PlusIcon,
    TagIcon,
    ClipboardDocumentCheckIcon,
    DeviceTabletIcon,
    RadioIcon,
    CubeIcon,
    PlayIcon,
    IdentificationIcon,
    CalendarIcon,
    HomeModernIcon,
    ArrowRightOnRectangleIcon,
    ArrowLeftOnRectangleIcon,
    ChatBubbleLeftRightIcon,
    UserPlusIcon,
    ShoppingCartIcon,
    WrenchIcon
} from '@heroicons/vue/24/outline'
import ThemeProvider from '@/Components/ThemeProvider.vue'

const props = defineProps({
    title: {
        type: String,
        default: 'Dashboard'
    },
    user: {
        type: Object,
        default: () => ({})
    },
    navigation: {
        type: Array,
        default: () => []
    }
})

const page = usePage()
const sidebarOpen = ref(false)
const profileDropdownOpen = ref(false)
const openSubmenus = ref([])
const sidebarHovered = ref(false)
const sidebarExpanded = ref(true)

const toggleSubmenu = (name) => {
    // Toggle the clicked submenu
    const index = openSubmenus.value.indexOf(name)
    if (index > -1) {
        openSubmenus.value.splice(index, 1)
    } else {
        openSubmenus.value.push(name)
    }
}

const closeSidebarOnMobile = () => {
    // Only close sidebar on mobile devices, keep submenus open
    if (window.innerWidth < 1024) {
        sidebarOpen.value = false
    }
}

const isActive = (routeName) => {
    return page.url === routeName
}

const isSubmenuOpen = (name) => {
    return openSubmenus.value.includes(name)
}

// Helper computed properties to handle different user object structures
const getUserInitials = computed(() => {
    if (!props.user) return 'U'

    // Try different possible user object structures
    if (props.user.first_name && props.user.last_name) {
        return props.user.first_name.charAt(0) + props.user.last_name.charAt(0)
    }

    if (props.user.name) {
        const nameParts = props.user.name.split(' ')
        if (nameParts.length >= 2) {
            return nameParts[0].charAt(0) + nameParts[nameParts.length - 1].charAt(0)
        }
        return nameParts[0].charAt(0) + nameParts[0].charAt(1)
    }

    if (props.user.email) {
        return props.user.email.charAt(0).toUpperCase()
    }

    return 'U'
})

const getUserName = computed(() => {
    if (!props.user) return 'User'

    // Try different possible user object structures
    if (props.user.full_name) {
        return props.user.full_name
    }

    if (props.user.first_name && props.user.last_name) {
        return `${props.user.first_name} ${props.user.last_name}`
    }

    if (props.user.name) {
        return props.user.name
    }

    if (props.user.email) {
        return props.user.email.split('@')[0]
    }

    return 'User'
})

const getUserRole = computed(() => {
    if (!props.user) return 'Staff'

    // Try different possible role structures
    if (props.user.roles && props.user.roles.length > 0) {
        const role = props.user.roles[0]
        if (role.display_name) {
            return role.display_name
        }
        if (role.name) {
            return role.name.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase())
        }
    }

    if (props.user.role) {
        return props.user.role.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase())
    }

    return 'Staff'
})

const resolvedNavigation = computed(() => {
    // Try to get role from multiple sources
    let roleName = null

    // 1. Check page.props.auth.user (standard Laravel auth)
    if (page.props?.auth?.user?.roles?.[0]?.name) {
        roleName = page.props.auth.user.roles[0].name
    }
    // 2. Check props.user.roles (passed as prop from controller)
    else if (props.user?.roles?.[0]?.name) {
        roleName = props.user.roles[0].name
    }
    // 3. Check page.props.user (alternative prop location)
    else if (page.props?.user?.roles?.[0]?.name) {
        roleName = page.props.user.roles[0].name
    }

    return roleName ? getNavigationForRole(roleName) : []
})

const canAccessPOS = computed(() => {
    // Manager area: always show POS in header when under /manager (reactive via usePage)
    const url = page.url || ''
    if (url.startsWith('/manager')) {
        return true
    }
    if (!props.user) return false

    // Check if user has POS permissions
    if (props.user.permissions) {
        return props.user.permissions.some(permission =>
            permission.name === 'access_pos' || permission === 'access_pos'
        )
    }

    // Check by role (case-insensitive) - include all customer-facing roles
    if (props.user.roles && props.user.roles.length > 0) {
        const roleName = (props.user.roles[0].name || '').toLowerCase()
        return ['admin', 'manager', 'front_desk', 'bartender', 'chef', 'server', 'bar_staff', 'restaurant_staff'].includes(roleName)
    }

    return false
})

const posRoute = computed(() => {
    // If we're on manager area, use manager POS (reactive via usePage)
    const url = page.url || ''
    if (url.startsWith('/manager')) {
        return route('manager.pos.index')
    }
    if (!props.user || !props.user.roles || props.user.roles.length === 0) {
        return route('pos.index') // Default to admin route
    }

    const roleName = (props.user.roles[0].name || '').toLowerCase()

    // Return appropriate POS route based on role
    if (roleName === 'front_desk') {
        return route('front-desk.pos.index')
    } else if (roleName === 'manager') {
        return route('manager.pos.index')
    } else {
        return route('pos.index') // Admin route
    }
})

// Theme Management
const themeSettings = ref({
    theme_mode: 'dark',
    theme_primary_color: '#FFD700', // Kotel Yellow
    theme_secondary_color: '#87CEEB', // Sky Blue
    theme_background_color: '#000000', // Black
    theme_sidebar_color: '#1a1a1a', // Dark Gray
    theme_card_color: '#111827', // Dark Blue-Gray
    theme_text_primary: '#ffffff', // White
    theme_text_secondary: '#87CEEB', // Sky Blue
    theme_text_tertiary: '#D1D5DB', // Light Gray
    theme_border_color: '#374151', // Gray
    theme_success_color: '#10B981', // Green
    theme_warning_color: '#F97316', // Orange
    theme_danger_color: '#EF4444', // Red
    theme_info_color: '#8B5CF6', // Purple
    theme_font_family: 'Figtree, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, sans-serif',
    theme_radius: '0.5rem',
    theme_shadow: '0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)',
    theme_transition: 'all 0.3s ease-in-out',
})

const loadThemeSettings = async () => {
    try {
        const response = await fetch('/api/theme/settings')
        if (response.ok) {
            const settings = await response.json()
            themeSettings.value = { ...themeSettings.value, ...settings }
            applyThemeToDOM()
        } else {
            // Fallback to default theme
            applyThemeToDOM()
        }
    } catch (error) {
        console.warn('Failed to load theme settings:', error)
        applyThemeToDOM()
    }
}

const applyThemeToDOM = () => {
    const root = document.documentElement

    // Set CSS custom properties
    root.style.setProperty('--theme-primary', themeSettings.value.theme_primary_color)
    root.style.setProperty('--theme-secondary', themeSettings.value.theme_secondary_color)
    root.style.setProperty('--theme-success', themeSettings.value.theme_success_color)
    root.style.setProperty('--theme-warning', themeSettings.value.theme_warning_color)
    root.style.setProperty('--theme-danger', themeSettings.value.theme_danger_color)
    root.style.setProperty('--theme-background', themeSettings.value.theme_background_color)
    root.style.setProperty('--theme-sidebar', themeSettings.value.theme_sidebar_color)
    root.style.setProperty('--theme-card', themeSettings.value.theme_card_color)
    root.style.setProperty('--theme-text-primary', themeSettings.value.theme_text_primary)
    root.style.setProperty('--theme-text-secondary', themeSettings.value.theme_text_secondary)
    root.style.setProperty('--theme-text-tertiary', themeSettings.value.theme_text_tertiary)
    root.style.setProperty('--theme-border', themeSettings.value.theme_border_color)
    root.style.setProperty('--theme-radius', themeSettings.value.theme_radius)
    root.style.setProperty('--theme-shadow', themeSettings.value.theme_shadow)
    root.style.setProperty('--theme-transition', themeSettings.value.theme_transition)

    // Apply theme mode
    if (themeSettings.value.theme_mode === 'dark') {
        document.documentElement.classList.add('dark')
    } else {
        document.documentElement.classList.remove('dark')
    }
}

// Handle mouse events for sidebar
const handleMouseEnter = () => {
    if (!sidebarExpanded.value && window.innerWidth >= 1280) {
        sidebarHovered.value = true
    }
}

const handleMouseLeave = () => {
    sidebarHovered.value = false
}

// Initialize theme on mount
onMounted(() => {
    loadThemeSettings()
})

// Clean up on unmount
onUnmounted(() => {
    // Cleanup if needed
})

</script>
